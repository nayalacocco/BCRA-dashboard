# BCRA API - No requiere token para endpoints públicos
# Pero podés configurar un token si el BCRA lo implementa en el futuro
BCRA_API_TOKEN=

# Base URL de la API del BCRA (no modificar salvo que cambie)
BCRA_API_BASE_URL=https://api.bcra.gob.ar

# MAE MarketData API — Mercado Abierto Electrónico
# Obtener key en: atencionalcliente@a3mercados.com.ar
# Prod: https://api.mae.com.ar/MarketData/v1
# UAT:  https://apiuat.mae.com.ar/MarketData/v1
MAE_API_KEY=

# Secret para proteger el endpoint de revalidación de caché
# Generá uno aleatorio: openssl rand -hex 32
CRON_SECRET=tu-secret-aleatorio-aqui

# Solo necesario si hacés revalidación on-demand desde GitHub Actions:
# VERCEL_REVALIDATION_URL=https://tu-app.vercel.app/api/cron/revalidate
